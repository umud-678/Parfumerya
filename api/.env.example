PORT=5005

# Vercel sayt ünvanları (vergüllə ayırın)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://YOUR-STORE.vercel.app,https://YOUR-ADMIN.vercel.app

# OTP e-poçt (production üçün doldurun; boş qalsa dev rejimdə kod konsola yazılır)
