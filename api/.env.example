SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Amoria <noreply@parfumerya.az>

# OTP hash üçün gizli açar (production-da mütləq dəyişin)
OTP_SECRET=change-me-in-production
